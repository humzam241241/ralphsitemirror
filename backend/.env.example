# Ryan's Roofing API - Environment Variables
# Copy to .env and fill in your values

# Anthropic API key for Raffy AI (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ChromaDB persistence directory for knowledge base
CHROMA_PERSIST_DIR=./chroma_db

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# SMTP settings for email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password

# Cal.com API key for booking integration
CAL_COM_API_KEY=your_cal_com_api_key_here
